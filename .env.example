# KAIROS Paths
KAIROS_ROOT=D:\KAIROS-KIT
OBSIDIAN_VAULT_PATH=C:\Users\pro\ObsidianVaults\KAIROS_Vault

# Asset Storage
ASSET_STORAGE_PROVIDER=local
ASSET_LIBRARY_PATH=D:\KAIROS_ASSET_LIBRARY

# Local LLM (optional)
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_ENDPOINT=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2

# Automation (n8n, Telegram 등 나중에 사용)
N8N_WEBHOOK_URL=
N8N_API_KEY=

# Messenger
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
